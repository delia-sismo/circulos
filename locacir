<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Localización con tiempos S–P</title>

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css">
  <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>

  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
                   Roboto, Arial, sans-serif;
      margin: 0;
      padding: 0;
      background: #f0f4f7;
    }
    .card {
      background: #ffffff;
      border-radius: 16px;
      max-width: 760px;
      margin: 16px auto;
      padding: 18px;
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.12);
    }
    h1 {
      margin: 0 0 4px;
      text-align: center;
      color: #004b6b;
      font-size: 1.4rem;
    }
    p.desc {
      margin: 0 0 12px;
      font-size: 0.9rem;
      text-align: center;
      color: #444;
    }
    .toolbar {
      display: flex;
      justify-content: center;
      margin-bottom: 8px;
    }
    .toolbar button {
      border-radius: 999px;
      border: 1px solid #2563eb;
      background: #2563eb;
      color: #fff;
      font-size: 0.9rem;
      padding: 6px 14px;
      cursor: pointer;
    }
    .toolbar button:hover { background: #1d4ed8; }
    .slot {
      border-top: 1px solid #e1e5ea;
      padding-top: 8px;
      margin-top: 8px;
    }
    .slot-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.85rem;
      margin-bottom: 4px;
    }
    .btn-remove-slot {
      background: transparent;
      border: none;
      color: #c62828;
      font-size: 1.1rem;
      cursor: pointer;
      padding: 0 6px;
    }
    .btn-remove-slot:hover { color: #8e0000; }
    .color-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      margin-right: 6px;
      flex-shrink: 0;
    }
    .slot-title {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-weight: 600;
      color: #004b6b;
    }
    .slot-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr 1fr 0.8fr 1fr 1fr;
      gap: 8px;
      align-items: end;
    }
    label {
      font-size: 0.8rem;
      color: #333;
    }
    input[type="text"], input[type="number"] {
      width: 100%;
      padding: 6px 8px;
      border-radius: 8px;
      border: 1px solid #ccd3da;
      font-size: 0.85rem;
      box-sizing: border-box;
    }
    .calc-box {
      font-size: 0.8rem;
      color: #333;
      text-align: center;
      padding-bottom: 4px;
    }
    .calc-box span.value {
      font-weight: 600;
      color: #111;
      min-width: 60px;
      display: inline-block;
    }
    #map {
      width: 100%;
      height: 380px;
      border-radius: 12px;
      border: 1px solid #dde3ea;
      margin-top: 12px;
    }
    .station-tooltip {
      background: rgba(0,0,0,0.8);
      color: #fff;
      border-radius: 4px;
      padding: 2px 4px;
      font-size: 11px;
      border: none;
    }
    .epic-info, .depth-info {
      margin-top: 6px;
      font-size: 0.82rem;
      color: #333;
      text-align: center;
    }
    .epic-info .value, .depth-info .value {
      font-weight: 600;
      color: #111;
      min-width: 80px;
      display: inline-block;
    }
    .note {
      font-size: 0.78rem;
      color: #555;
      text-align: center;
      margin-top: 8px;
    }
    footer {
      margin-top: 18px;
      text-align: center;
      color: #004b6b;
      font-size: 0.85rem;
      padding-bottom: 14px;
    }
    footer img {
      width: 160px;
      height: auto;
      margin-bottom: 6px;
    }
    @media (max-width: 720px) {
      .slot-grid { grid-template-columns: 1fr 1fr; }
      .card { margin: 8px; }
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Localización con tiempos S–P</h1>
    <p class="desc">
      Agrega estaciones manualmente, escribe <strong>S–P</strong> y se dibuja el círculo correspondiente.
      Marca el epicentro haciendo clic en el mapa para estimar la profundidad.
    </p>

    <div class="toolbar">
      <button id="btnAddSlot">➕ Agregar estación</button>
    </div>

    <div id="slots"></div>

    <div id="map"></div>

    <div class="epic-info">
      Punto marcado en el mapa:<br>
      Latitud: <span id="epicLat" class="value">—</span>°
      &nbsp;|&nbsp;
      Longitud: <span id="epicLon" class="value">—</span>°
    </div>

    <div class="depth-info">
      Profundidad promedio estimada:
      <span id="depthMean" class="value">—</span> km
    </div>

    <div class="note">
      Distancia hipocentral aproximada = 8 × (S–P).<br>
      Profundidad = √[(distancia hipocentral)² − (distancia epicentral)²].
    </div>
  </div>

  <footer>
    <img src="./SSN.png" alt="Logo del Servicio Sismológico Nacional">
    <br>
    Aplicación educativa – Servicio Sismológico Nacional
  </footer>

  <script>
    const SPEED = 8; // km/s, aproximación educativa: distancia hipocentral = S-P × 8
    const SLOT_COLORS = ['#c62828','#1565c0','#2e7d32','#6a1b9a','#ef6c00','#00838f','#8e24aa'];

    const slotsContainer = document.getElementById('slots');
    const btnAddSlot = document.getElementById('btnAddSlot');
    const slotState = [];

    const map = L.map('map').setView([23, -102], 5.3);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    let epicenterMarker = null;
    let epicenterLatLng = null;

    map.on('click', function (e) {
      epicenterLatLng = e.latlng;

      if (epicenterMarker) map.removeLayer(epicenterMarker);

      epicenterMarker = L.marker(e.latlng).addTo(map)
        .bindPopup(`<b>Epicentro seleccionado</b><br>Lat: ${e.latlng.lat.toFixed(4)}°<br>Lon: ${e.latlng.lng.toFixed(4)}°`)
        .openPopup();

      document.getElementById('epicLat').textContent = e.latlng.lat.toFixed(4);
      document.getElementById('epicLon').textContent = e.latlng.lng.toFixed(4);

      updateAllSlots();
    });

    function createSlot() {
      const index = slotState.length;
      const color = SLOT_COLORS[index % SLOT_COLORS.length];

      const slot = document.createElement('div');
      slot.className = 'slot';

      slot.innerHTML = `
        <div class="slot-header">
          <div class="slot-title">
            <span class="color-dot" style="background:${color};"></span>
            Estación ${index + 1}
          </div>
          <button class="btn-remove-slot">❌</button>
        </div>

        <div class="slot-grid">
          <div>
            <label>Nombre</label>
            <input type="text" class="inp-name" placeholder="Ej. CUIG">
          </div>
          <div>
            <label>Latitud</label>
            <input type="number" step="0.000001" class="inp-lat" placeholder="19.329">
          </div>
          <div>
            <label>Longitud</label>
            <input type="number" step="0.000001" class="inp-lon" placeholder="-99.178">
          </div>
          <div>
            <label>S–P (s)</label>
            <input type="number" step="0.1" min="0" class="inp-sp" placeholder="3.5">
          </div>
          <div class="calc-box">
            Dist. S–P:<br>
            <span class="value dist-sp">—</span> km
          </div>
          <div class="calc-box">
            Prof.:<br>
            <span class="value depth">—</span> km
          </div>
        </div>
      `;

      slotsContainer.appendChild(slot);

      const state = {
        slot,
        nameInput: slot.querySelector('.inp-name'),
        latInput: slot.querySelector('.inp-lat'),
        lonInput: slot.querySelector('.inp-lon'),
        spInput: slot.querySelector('.inp-sp'),
        distSpan: slot.querySelector('.dist-sp'),
        depthSpan: slot.querySelector('.depth'),
        marker: null,
        circle: null,
        color
      };

      slotState.push(state);

      [state.nameInput, state.latInput, state.lonInput, state.spInput].forEach(el => {
        el.addEventListener('input', () => updateSlot(state));
      });

      slot.querySelector('.btn-remove-slot').addEventListener('click', () => {
        if (state.marker) map.removeLayer(state.marker);
        if (state.circle) map.removeLayer(state.circle);

        const i = slotState.indexOf(state);
        if (i >= 0) slotState.splice(i, 1);

        slot.remove();
        updateMeanDepth();
      });
    }

    function updateAllSlots() {
      slotState.forEach(updateSlot);
    }

    function updateSlot(state) {
      const name = state.nameInput.value.trim() || 'Estación';
      const lat = parseFloat(state.latInput.value);
      const lon = parseFloat(state.lonInput.value);
      const sp = parseFloat(state.spInput.value);

      if (state.marker) {
        map.removeLayer(state.marker);
        state.marker = null;
      }
      if (state.circle) {
        map.removeLayer(state.circle);
        state.circle = null;
      }

      state.distSpan.textContent = '—';
      state.depthSpan.textContent = '—';
      state.depthValue = null;

      if (!isFinite(lat) || !isFinite(lon)) {
        updateMeanDepth();
        return;
      }

      state.marker = L.marker([lat, lon]).addTo(map);
      state.marker.bindTooltip(name, {
        permanent: true,
        direction: 'top',
        offset: [0, -10],
        className: 'station-tooltip'
      });

      if (!isFinite(sp) || sp <= 0) {
        updateMeanDepth();
        return;
      }

      const hypoDistKm = sp * SPEED;
      state.distSpan.textContent = hypoDistKm.toFixed(1);

      state.circle = L.circle([lat, lon], {
        radius: hypoDistKm * 1000,
        color: state.color,
        weight: 2,
        fillColor: state.color,
        fillOpacity: 0.18
      }).addTo(map);

      if (epicenterLatLng) {
        const epicDistKm = haversineKm(lat, lon, epicenterLatLng.lat, epicenterLatLng.lng);
        const depthSquared = hypoDistKm * hypoDistKm - epicDistKm * epicDistKm;

        if (depthSquared >= 0) {
          const depthKm = Math.sqrt(depthSquared);
          state.depthValue = depthKm;
          state.depthSpan.textContent = depthKm.toFixed(1);
        } else {
          state.depthSpan.textContent = 'sin solución';
        }
      }

      updateMeanDepth();
    }

    function updateMeanDepth() {
      const values = slotState
        .map(s => s.depthValue)
        .filter(v => isFinite(v));

      const depthMean = document.getElementById('depthMean');

      if (values.length === 0) {
        depthMean.textContent = '—';
        return;
      }

      const mean = values.reduce((a, b) => a + b, 0) / values.length;
      depthMean.textContent = mean.toFixed(1);
    }

    function haversineKm(lat1, lon1, lat2, lon2) {
      const R = 6371;
      const toRad = deg => deg * Math.PI / 180;
      const dLat = toRad(lat2 - lat1);
      const dLon = toRad(lon2 - lon1);
      const a = Math.sin(dLat / 2) ** 2 +
                Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
                Math.sin(dLon / 2) ** 2;
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      return R * c;
    }

    createSlot();
    btnAddSlot.addEventListener('click', createSlot);
  </script>
</body>
</html>
